# ============================================================
# SecureVote Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git!
# ============================================================

# Flask Secret Key (change this to a long random string in production)
SECRET_KEY=your-long-random-secret-key-here

# ---- MSG91 OTP Service (Primary - recommended for India) ----
# Get your Authkey from: https://control.msg91.com/app/#/authkey
MSG91_AUTH_KEY=your_msg91_authkey_here
# Get Widget ID from: https://control.msg91.com/app/m/l/otp/widgets
MSG91_WIDGET_ID=your_msg91_widget_id_here

# ---- Fast2SMS (Backup SMS for India) ----
# Get API Key from: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ---- Twilio (International SMS fallback) ----
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ---- Gmail SMTP (for Email OTP) ----
# Use a Google App Password (NOT your main Gmail password)
# Enable 2FA then create App Password at: https://myaccount.google.com/apppasswords
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_16_digit_app_password_here
